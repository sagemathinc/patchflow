{
  "name": "patchflow",
  "version": "0.7.1",
  "private": false,
  "description": "Lightweight patch-based directed acyclic graph realtime sync core",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sagemathinc/patchflow.git"
  },
  "bugs": {
    "url": "https://github.com/sagemathinc/patchflow/issues"
  },
  "homepage": "https://github.com/sagemathinc/patchflow#readme",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist/esm/**/*",
    "dist/cjs/**/*",
    "dist/types/**/*",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "pnpm build:types && pnpm build:esm && pnpm build:cjs",
    "build:esm": "rollup -c",
    "build:cjs": "tsc -p tsconfig.cjs.json && node scripts/postbuild-cjs.cjs",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "jest --runInBand",
    "clean": "rm -rf dist node_modules",
    "lint": "oxlint --deny-warnings src",
    "lint:fix": "oxlint --fix src",
    "format": "prettier --write .",
    "check": "pnpm format && pnpm test && pnpm lint",
    "example:basic": "pnpm build && node dist/esm/examples/basic-session.js",
    "example:tcp:server": "pnpm build && node dist/esm/examples/tcp-session.js --role=server --file=/tmp/patchflow-a.txt",
    "example:tcp:client": "pnpm build && node dist/esm/examples/tcp-session.js --role=client --file=/tmp/patchflow-b.txt",
    "example:tcp:server:ts": "node --loader ts-node/esm --experimental-specifier-resolution=node examples/tcp-session.ts --role=server --file=/tmp/patchflow-a.txt",
    "example:tcp:client:ts": "node --loader ts-node/esm --experimental-specifier-resolution=node examples/tcp-session.ts --role=client --file=/tmp/patchflow-b.txt --host=127.0.0.1",
    "example:db-immer:server": "pnpm build && node dist/esm/examples/db-immer-session.js --role=server",
    "example:db-immer:client": "pnpm build && node dist/esm/examples/db-immer-session.js --role=client --host=127.0.0.1",
    "example:db-immer:server:ts": "node --loader ts-node/esm --experimental-specifier-resolution=node examples/db-immer-session.ts --role=server",
    "example:db-immer:client:ts": "node --loader ts-node/esm --experimental-specifier-resolution=node examples/db-immer-session.ts --role=client --host=127.0.0.1",
    "bench:immer": "node --loader ts-node/esm --experimental-specifier-resolution=node examples/bench-immer-apply.ts"
  },
  "dependencies": {
    "@cocalc/diff-match-patch": "^1.0.0",
    "events": "^3.3.0",
    "fast-deep-equal": "^3.1.3",
    "fast-json-stable-stringify": "^2.1.0",
    "immer": "^10.2.0",
    "immutable": "^4.3.8",
    "lru-cache": "^11.0.1",
    "save-dev": "0.0.1-security"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.9.0",
    "jest": "^29.7.0",
    "oxlint": "^1.61.0",
    "prettier": "^3.2.5",
    "rollup": "^4.59.0",
    "rollup-plugin-typescript2": "^0.37.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "ajv@>=6.0.0 <6.14.0": "^6.14.0",
      "brace-expansion@>=1.0.0 <1.1.13": "^1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "^2.0.3",
      "diff@>=4.0.0 <4.0.4": "^4.0.4",
      "flatted@<3.4.2": "^3.4.2",
      "handlebars@<4.7.9": "^4.7.9",
      "minimatch@>=3.0.0 <3.1.4": "^3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "picomatch@>=2.0.0 <2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4"
    }
  },
  "ts-node": {
    "esm": {
      "resolveExtensions": [
        ".ts",
        ".tsx",
        ".js"
      ],
      "experimentalSpecifierResolution": "node",
      "preferTsExts": true
    },
    "compilerOptions": {
      "module": "NodeNext",
      "moduleResolution": "NodeNext"
    }
  }
}
